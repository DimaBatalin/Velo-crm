# Database
# The password here MUST match POSTGRES_PASSWORD below.
DATABASE_URL=postgresql+asyncpg://velo:velo123@postgres:5432/velo
POSTGRES_PASSWORD=velo123

# JWT — generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — comma-separated list of allowed frontend origins.
# In production the frontend is same-origin behind nginx, so this is only
# needed for direct API access. Example: http://201.51.13.156
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# First admin user (created on first startup if DB has no users)
FIRST_ADMIN_EMAIL=velo@velo.local
FIRST_ADMIN_PASSWORD=changeme
FIRST_ADMIN_NAME=Admin

# SQL query logging (set to true only for debugging)
SQL_ECHO=false
