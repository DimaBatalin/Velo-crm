# Database
DATABASE_URL=postgresql+asyncpg://velo:velo123@postgres:5432/velo
POSTGRES_PASSWORD=velo123

# JWT — generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — comma-separated list of allowed frontend origins
# Example: http://yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# First admin user (created on first startup if DB has no users)
FIRST_ADMIN_EMAIL=velo@velo.local
FIRST_ADMIN_PASSWORD=changeme
FIRST_ADMIN_NAME=Admin

# SQL query logging (set to true only for debugging)
SQL_ECHO=false
